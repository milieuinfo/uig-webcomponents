{
    "$schema": "../../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "libs/publish/dv-components/src",
    "projectType": "library",
    "targets": {
        "build": {
            "executor": "@nrwl/js:tsc",
            "outputs": ["{options.outputPath}"],
            "options": {
                "outputPath": "dist/libs/publish/dv-components",
                "main": "libs/publish/dv-components/src/index.ts",
                "tsConfig": "libs/publish/dv-components/tsconfig.lib.json",
                "assets": ["libs/publish/dv-components/*.md"]
            }
        },
        "lint": {
            "executor": "@nrwl/linter:eslint",
            "outputs": ["{options.outputFile}"],
            "options": {
                "lintFilePatterns": ["libs/publish/dv-components/**/*.ts"]
            }
        },
        "test": {
            "executor": "@nrwl/jest:jest",
            "outputs": ["coverage/libs/publish/dv-components"],
            "options": {
                "jestConfig": "libs/publish/dv-components/jest.config.ts",
                "passWithNoTests": true
            }
        }
    },
    "tags": []
}
